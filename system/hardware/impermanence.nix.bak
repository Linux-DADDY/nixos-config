{
  inputs,
  username,
  ...
}: {
  imports = [inputs.impermanence.nixosModules.impermanence];

  programs.fuse.userAllowOther = true;
  users.users.${username}.extraGroups = ["fuse"];

  # 💥 Nuke root AND home subvolumes on every boot
  boot.initrd.postDeviceCommands = ''
    mkdir -p /btrfs_tmp
    mount /dev/mapper/cryptroot /btrfs_tmp

    delete_subvolume_recursively() {
        IFS=$'\n'
        for i in $(btrfs subvolume list -o "$1" | cut -f 9- -d ' '); do
            delete_subvolume_recursively "/btrfs_tmp/$i"
        done
        btrfs subvolume delete "$1"
    }

    # Nuke and recreate root
    delete_subvolume_recursively /btrfs_tmp/root
    btrfs subvolume create /btrfs_tmp/root

    # Nuke and recreate home (this wipes /home/${username} — but we restore via impermanence)
    delete_subvolume_recursively /btrfs_tmp/home
    btrfs subvolume create /btrfs_tmp/home

    umount /btrfs_tmp
  '';

  # System persistence
  environment.persistence."/persist" = {
    enable = true;
    hideMounts = true;

    directories = [
      "/var/lib/nixos"
      "/var/lib/systemd/coredump"
      "/var/lib/bluetooth"
      "/var/lib/NetworkManager"
      "/etc/NetworkManager/system-connections"
      {
        directory = "/etc/ssh";
        mode = "0755";
      }
      "/etc/nixos"
    ];

    files = [
      "/etc/machine-id"
      # "/etc/hosts"
    ];
  };

  security.sudo.extraConfig = "Defaults lecture = never";

  # Ensure persisted home structure exists
  systemd.tmpfiles.rules = [
    "d /persist/home 0755 root root -"
    "d /persist/home/${username} 0750 ${username} ${username} -"
  ];
}
